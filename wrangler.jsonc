{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "shadcn",
  "main": "./worker/index.js",
  "compatibility_date": "2026-04-29",
  "keep_vars": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "404-page"
  }
}
